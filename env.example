# ─────────────────────────────────────────────────
#  CryptoMiner Galaxy — Environment Variables
#  Copy this file to ".env" and fill in your values
# ─────────────────────────────────────────────────

# Your Telegram Bot token (from @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your bot's @username WITHOUT the @ symbol
BOT_USERNAME=CryptoMinerGalaxyBot

# The public URL of your Railway deployment
# You get this after deploying — looks like: https://your-app-name.up.railway.app
WEBAPP_URL=https://your-app-name.up.railway.app

# Set to "production" on Railway, "development" locally
NODE_ENV=production

# Railway sets this automatically — leave as-is
PORT=3000

# Optional: custom path for the SQLite database
# DB_PATH=/data/game.db
